#include <Wire.h>
#include <Adafruit_PWMServoDriver.h>

Adafruit_PWMServoDriver pwm(0x40);

#define SERVOMIN 90
#define SERVOMAX 560

// ---------------- SERVOS ----------------
const int servoLR   = 0;
const int servoUD   = 1;
const int servoLID  = 2;
const int servoBUD  = 3;
const int servoBLR  = 4;
const int servoMOUTH = 5;
const int servoHEAD  = 6;

// ---------------- OGEN ----------------
const float lr_min = 75, lr_max = 105;
const float ud_min = 60, ud_max = 120;

float lr_pos = 90, lr_target = 90;
float ud_pos = 90, ud_target = 90;

const float lr_fast = 160, lr_slow = 30;
const float ud_fast = 120, ud_slow = 25;

// ---------------- OOGLEDEN ----------------
enum LidState {
  LID_OPEN,
  LID_BLINK_CLOSE,
  LID_BLINK_OPEN,
  LID_SQUINT
};

LidState lidState = LID_OPEN;

const float lid_open   = 90;
const float lid_half   = 110;
const float lid_closed = 118;

float lid_pos = lid_open;
float lid_target = lid_open;

unsigned long lidHoldUntil = 0;

const float lid_speed_blink  = 280;
const float lid_speed_squint = 100;

// ---------------- WENKBRAUWEN ----------------
const float brow_ud_min = 65;
const float brow_ud_max = 90;

float brow_ud_pos = 90;
float brow_ud_target = 90;

const float brow_ud_speed = 20;
const int brow_ud_chance = 1200;

const float brow_lr_min = 70;
const float brow_lr_max = 120;

float brow_lr_pos = 90;
float brow_lr_target = 90;

const float brow_lr_speed = 25;
const int brow_lr_chance = 900;

// ---------------- MOND ----------------
const float mouth_happy = 60;
const float mouth_sad   = 130;
const float mouth_neutral = 100;

float mouth_pos = 90;
float mouth_target = 90;

const float mouth_speed = 35;

unsigned long mouthHoldUntil = 0;

// ---------------- HOOFD ----------------
const float head_min = 70;
const float head_max = 110;

float head_pos = 90;
float head_target = 90;

const float head_speed = 15;

unsigned long headNextMove = 0;

// ---------------- TIMING ----------------
unsigned long lastUpdate = 0;
unsigned long pauseUntil = 0;

const unsigned long updateInterval = 8;

// ---------------- HULPFUNCTIE ----------------
int gradenNaarPWM(float graden) {
  graden = constrain(graden, 0, 180);
  return map(graden * 100, 0, 18000, SERVOMIN, SERVOMAX);
}

void startBlink() {
  lidState = LID_BLINK_CLOSE;
  lid_target = lid_closed;
}

void startSquint(unsigned long now) {
  lidState = LID_SQUINT;
  lid_target = lid_half;
  lidHoldUntil = now + random(1000, 3000);
}

// ---------------- WENKBRAUW FUNCTIES ----------------
void updateBrowUD(float dt) {

  if (random(0, brow_ud_chance) < 2) {
    brow_ud_target = random(brow_ud_min * 10, brow_ud_max * 10) / 10.0;
  }

  brow_ud_pos += constrain(brow_ud_target - brow_ud_pos,
                           -brow_ud_speed * dt,
                            brow_ud_speed * dt);

  pwm.setPWM(servoBUD, 0, gradenNaarPWM(brow_ud_pos));
}

void updateBrowLR(float dt) {

  if (random(0, brow_lr_chance) < 2) {
    brow_lr_target = random(brow_lr_min * 10, brow_lr_max * 10) / 10.0;
  }

  brow_lr_pos += constrain(brow_lr_target - brow_lr_pos,
                           -brow_lr_speed * dt,
                            brow_lr_speed * dt);

  pwm.setPWM(servoBLR, 0, gradenNaarPWM(brow_lr_pos));
}

// ---------------- MOND ----------------
void updateMouth(float dt, unsigned long now) {

  if (now > mouthHoldUntil) {

    int emotion = random(0, 100);

    if (emotion < 40) mouth_target = mouth_neutral;
    else if (emotion < 70) mouth_target = mouth_happy;
    else mouth_target = mouth_sad;

    mouthHoldUntil = now + random(1500, 4000);
  }

  float dist = abs(mouth_target - mouth_pos);

  float speed = (dist > 5)
      ? mouth_speed
      : map(dist * 100, 0, 500, 10 * 100, mouth_speed * 100) / 100.0;

  mouth_pos += constrain(mouth_target - mouth_pos, -speed * dt, speed * dt);

  pwm.setPWM(servoMOUTH, 0, gradenNaarPWM(mouth_pos));
}

// ---------------- HOOFD ----------------
void updateHead(float dt, unsigned long now) {

  if (now > headNextMove) {

    head_target = random(head_min * 10, head_max * 10) / 10.0;

    headNextMove = now + random(10000, 20000);
  }

  float dist = abs(head_target - head_pos);

  float speed = (dist > 3)
      ? head_speed
      : map(dist * 100, 0, 300, 5 * 100, head_speed * 100) / 100.0;

  head_pos += constrain(head_target - head_pos, -speed * dt, speed * dt);

  pwm.setPWM(servoHEAD, 0, gradenNaarPWM(head_pos));
}

// ---------------- SETUP ----------------
void setup() {

  pwm.begin();
  pwm.setPWMFreq(50);

  delay(300);

  randomSeed(analogRead(A0));
}

// ---------------- LOOP ----------------
void loop() {

  unsigned long now = millis();

  if (now - lastUpdate < updateInterval) return;

  float dt = (now - lastUpdate) / 1000.0;
  lastUpdate = now;

  // ---------- PAUZE ----------
  if (now < pauseUntil) {

    if (lidState == LID_OPEN && random(0, 1000) < 3) startBlink();
    if (lidState == LID_OPEN && random(0, 5000) < 2) startSquint(now);

    float speed = (lidState == LID_SQUINT) ? lid_speed_squint : lid_speed_blink;

    lid_pos += constrain(lid_target - lid_pos, -speed * dt, speed * dt);

    switch (lidState) {

      case LID_BLINK_CLOSE:
        if (abs(lid_pos - lid_closed) < 1) {
          lidState = LID_BLINK_OPEN;
          lid_target = lid_open;
        }
      break;

      case LID_BLINK_OPEN:
        if (abs(lid_pos - lid_open) < 1) {
          lidState = LID_OPEN;
          if (random(0,100) < 15) startBlink();
        }
      break;

      case LID_SQUINT:
        lid_target = lid_half + sin(now * 0.01) * 0.8;
        if (now > lidHoldUntil) {
          lidState = LID_BLINK_OPEN;
          lid_target = lid_open;
        }
      break;

      default:
      break;
    }

    pwm.setPWM(servoLID, 0, gradenNaarPWM(lid_pos));

    updateBrowUD(dt);
    updateBrowLR(dt);
    updateMouth(dt, now);
    updateHead(dt, now);

    return;
  }

  // ---------- NIEUWE OOGTARGETS ----------
  if (abs(lr_target - lr_pos) < 0.3 && abs(ud_target - ud_pos) < 0.3) {

    lr_target = random(lr_min * 10, lr_max * 10) / 10.0;

    if (random(0, 100) < 60)
      ud_target = random(ud_min * 10, ud_max * 10) / 10.0;

    pauseUntil = now + random(600, 2000);
  }

  // ---------- OGEN LINKS/RECHTS ----------
  float lr_dist = abs(lr_target - lr_pos);

  float lr_speed = (lr_dist > 5) ? lr_fast :
    map(lr_dist * 100, 0, 500, lr_slow * 100, lr_fast * 100) / 100.0;

  lr_pos += constrain(lr_target - lr_pos, -lr_speed * dt, lr_speed * dt);

  // ---------- OGEN OP/NEER ----------
  float ud_dist = abs(ud_target - ud_pos);

  float ud_speed = (ud_dist > 4) ? ud_fast :
    map(ud_dist * 100, 0, 400, ud_slow * 100, ud_fast * 100) / 100.0;

  ud_pos += constrain(ud_target - ud_pos, -ud_speed * dt, ud_speed * dt);

  pwm.setPWM(servoLR, 0, gradenNaarPWM(lr_pos));
  pwm.setPWM(servoUD, 0, gradenNaarPWM(ud_pos));

  updateBrowUD(dt);
  updateBrowLR(dt);
  updateMouth(dt, now);
  updateHead(dt, now);
}
